/* 菜系详情页样式 - cuisine-detail/index.wxss */

page {
  background-color: #F5F5F5;
  padding-bottom: 0;
}

.detail-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* ==================== Hero 区域 ==================== */
.cuisine-hero {
  padding: 60rpx 36rpx 48rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero-decoration {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.hero-emoji-big {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.hero-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.hero-full-name {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20rpx;
}

.hero-long-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
  padding: 0 20rpx;
  margin-bottom: 24rpx;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
}

.hero-tag {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 32rpx;
  padding: 10rpx 24rpx;
}

/* ==================== 通用区块 ==================== */
.section-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 20rpx 24rpx 0;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
}

.section-count {
  font-size: 24rpx;
  color: #AAAAAA;
}

/* ==================== 食材标签 ==================== */
.ingredient-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.ingredient-chip {
  font-size: 26rpx;
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  border: 2rpx solid;
  font-weight: 500;
}

/* ==================== 一键生成按钮 ==================== */
.generate-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
}

.generate-btn-icon {
  font-size: 32rpx;
}

.generate-btn-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* ==================== 难度筛选 ==================== */
.difficulty-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.difficulty-tabs {
  display: flex;
  gap: 12rpx;
  padding-bottom: 4rpx;
  white-space: nowrap;
}

.difficulty-tab {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666666;
  background: #F5F5F5;
  border: 2rpx solid #E8E8E8;
  white-space: nowrap;
  flex-shrink: 0;
}

.difficulty-tab-active {
  color: #FFFFFF !important;
  font-weight: 600;
}

/* ==================== 菜品列表 ==================== */
.dish-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.dish-item {
  border-bottom: 2rpx solid #F5F5F5;
}

.dish-item:last-child {
  border-bottom: none;
}

.dish-summary {
  display: flex;
  align-items: center;
  padding: 20rpx 4rpx;
  gap: 16rpx;
}

.dish-info {
  flex: 1;
}

.dish-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
}

/* 难度徽章 */
.dish-difficulty-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.badge-easy {
  background: #E8F5E9;
  color: #388E3C;
}

.badge-medium {
  background: #FFF8E1;
  color: #F57F17;
}

.badge-hard {
  background: #FCE4EC;
  color: #C62828;
}

.dish-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dish-time {
  font-size: 24rpx;
  color: #999999;
  flex-shrink: 0;
}

.dish-desc {
  font-size: 24rpx;
  color: #AAAAAA;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 展开箭头 */
.dish-expand-icon {
  font-size: 40rpx;
  color: #CCCCCC;
  font-weight: 300;
  transition: transform 0.2s;
  transform: rotate(0deg);
  flex-shrink: 0;
}

.dish-expand-icon.expanded {
  transform: rotate(90deg);
}

/* 展开的详情 */
.dish-detail {
  padding: 16rpx 4rpx 24rpx;
  border-top: 2rpx solid #F8F8F8;
}

.dish-ingredients-title {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 14rpx;
}

.dish-ingredients {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.dish-ingredient-chip {
  font-size: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  border: 2rpx solid;
}

/* AI生成按钮 */
.dish-ai-btn {
  display: block;
  text-align: center;
  padding: 16rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.no-dish {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #AAAAAA;
}

/* 云端已生成徽章 */
.dish-cached-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  background: #E3F2FD;
  color: #1565C0;
}

/* ==================== 加载中 ==================== */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 300rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #AAAAAA;
}

/* ==================== 菜谱弹窗 ==================== */
.recipe-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.recipe-modal {
  width: 100%;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 弹窗头部 */
.rm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  flex-shrink: 0;
}

.rm-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  flex: 1;
}

.rm-close {
  font-size: 36rpx;
  color: rgba(255,255,255,0.85);
  padding: 8rpx 16rpx;
  line-height: 1;
}

/* 来源标签行 */
.rm-source-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 32rpx 8rpx;
  flex-shrink: 0;
}

.rm-source-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.rm-source-badge.from-db {
  background: #E3F2FD;
  color: #1565C0;
}

.rm-source-badge.from-ai {
  background: #F3E5F5;
  color: #6A1B9A;
}

.rm-meta {
  font-size: 22rpx;
  color: #AAAAAA;
}

/* 加载中 */
.rm-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  gap: 24rpx;
}

.rm-loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #F0F0F0;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.rm-loading-text {
  font-size: 28rpx;
  color: #888888;
}

/* 错误状态 */
.rm-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  gap: 16rpx;
}

.rm-error-icon { font-size: 64rpx; }

.rm-error-msg {
  font-size: 26rpx;
  color: #888888;
  text-align: center;
  line-height: 1.6;
}

.rm-retry-btn {
  margin-top: 16rpx;
  padding: 16rpx 48rpx;
  background: #FF6B35;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 正文滚动区 */
.rm-body {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx 48rpx;
}

/* 菜谱描述 */
.rm-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.7;
  padding: 16rpx 0 12rpx;
  border-bottom: 2rpx solid #F5F5F5;
  margin-bottom: 16rpx;
}

/* 基本信息徽章 */
.rm-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F5F5F5;
  margin-bottom: 20rpx;
}

.rm-badge {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: #F8F8F8;
  border-radius: 24rpx;
  color: #555555;
}

/* 分区 */
.rm-section {
  margin-bottom: 24rpx;
}

.rm-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 16rpx;
}

/* 食材清单 */
.rm-ingredient-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rm-ingredient {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 12rpx 16rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  margin-right:25px;
}

.rm-ing-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.rm-ing-amount {
  font-size: 24rpx;
  color: #888888;
}

/* 步骤 */
.rm-step {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.rm-step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rm-step-body {
  flex: 1;
  padding-top: 8rpx;
}

.rm-step-desc {
  font-size: 25rpx;
  color: #333333;
  line-height: 1.7;
  display: block;
  padding-right: 25px;
}

.rm-step-tip {
  display: block;
  font-size: 24rpx;
  color: #F57C00;
  margin-top: 8rpx;
  line-height: 1.5;
}

/* 营养信息 */
.rm-nutrition {
  display: flex;
  justify-content: space-around;
  background: #FFF8F5;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
}

.rm-nut-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.rm-nut-val {
  font-size: 30rpx;
  font-weight: 700;
  color: #FF6B35;
}

.rm-nut-label {
  font-size: 22rpx;
  color: #AAAAAA;
}

/* 重新生成按钮 */
.rm-regen-btn {
  margin-top: 24rpx;
  margin-right: 24px;
  text-align: center;
  padding: 20rpx;
  border: 2rpx solid #DDDDDD;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #888888;
}

/* 海报生成按钮 */
.rm-poster-btn {
  margin-top: 20rpx;
  margin-right: 24px;
  text-align: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.35);
}

/* 隐藏画布 */
.poster-canvas-hidden {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 375px;
  height: 812px;
  opacity: 0;
  pointer-events: none;
}

/* ==================== 海报弹窗 ==================== */
.poster-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.65);
  z-index: 2000;
  display: flex;
  align-items: flex-end;
}

.poster-modal {
  width: 100%;
  max-height: 90vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.poster-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  flex-shrink: 0;
}

.poster-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.poster-modal-close {
  font-size: 36rpx;
  color: rgba(255,255,255,0.85);
  padding: 8rpx 16rpx;
}

/* 生成中 */
.poster-generating {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  gap: 24rpx;
}

.poster-spinner {
  width: 72rpx;
  height: 72rpx;
  border: 6rpx solid #F0F0F0;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.poster-gen-text {
  font-size: 28rpx;
  color: #888888;
}

/* 错误 */
.poster-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  gap: 16rpx;
}

.poster-error-icon { font-size: 64rpx; }

.poster-error-msg {
  font-size: 26rpx;
  color: #888888;
  text-align: center;
}

.poster-retry-btn {
  margin-top: 16rpx;
  padding: 16rpx 48rpx;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 预览 */
.poster-preview-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx 48rpx;
  gap: 16rpx;
  overflow-y: auto;
}

.poster-preview-img {
  width: 100%;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}

.poster-preview-hint {
  font-size: 24rpx;
  color: #AAAAAA;
}

.poster-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 8rpx;
}

.poster-save-btn {
  width: 100%;
  padding: 28rpx;
  text-align: center;
  color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.15);
}

.poster-preview-btn {
  width: 100%;
  padding: 24rpx;
  text-align: center;
  color: #666666;
  border: 2rpx solid #DDDDDD;
  border-radius: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
