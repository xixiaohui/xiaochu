<!-- pages/upload/index.wxml  v5.0.0 -->
<!-- 菜谱批量生成管理页 - 前端循环 + 单菜云函数架构 -->

<view class="page">

  <!-- ====== 页头 ====== -->
  <view class="page-header">
    <view class="header-row">
      <text class="header-icon">🍳</text>
      <view>
        <view class="header-title">小厨AI · 菜谱批量生成</view>
        <view class="header-sub">管理员工具 · 每次生成1道菜，不超时，可暂停</view>
      </view>
    </view>
  </view>

  <!-- ====== 数据库总览 ====== -->
  <view class="card" wx:if="{{dbSummary}}">
    <view class="card-title">📊 数据库状态</view>
    <view class="summary-row">
      <view class="summary-item">
        <text class="sum-num">{{dbSummary.totalCuisines}}</text>
        <text class="sum-label">个菜系</text>
      </view>
      <view class="summary-item">
        <text class="sum-num blue">{{dbSummary.totalInDB}}</text>
        <text class="sum-label">已生成</text>
      </view>
      <view class="summary-item">
        <text class="sum-num orange">{{dbSummary.pendingCount}}</text>
        <text class="sum-label">待生成</text>
      </view>
      <view class="summary-item">
        <text class="sum-num green">{{dbSummary.totalDishes}}</text>
        <text class="sum-label">总菜数</text>
      </view>
    </view>
    <view class="pbar-row">
      <view class="pbar-track">
        <view class="pbar-fill" style="width:{{dbSummary.overallPct}}%"></view>
      </view>
      <text class="pbar-pct">{{dbSummary.overallPctText}}%</text>
    </view>
  </view>

  <!-- ====== 实时进度（运行中 / 暂停）====== -->
  <view class="card progress-card {{isPaused ? 'paused' : ''}}" wx:if="{{isRunning || isStopped}}">
    <view class="pc-header">
      <text class="pc-title">{{isPaused ? '⏸ 已暂停' : isStopped ? '⏹ 已停止' : '⏳ 生成中...'}}</text>
      <text class="pc-pct">{{overallPct}}%</text>
    </view>
    <view class="pbar-track" style="margin-bottom:12rpx">
      <view class="pbar-fill {{isPaused ? 'paused' : 'running'}}" style="width:{{overallPct}}%"></view>
    </view>
    <view class="pc-dish" wx:if="{{currentDishName}}">
      <text class="pc-cuisine">{{currentCuisineName}}</text>
      <text class="pc-arrow"> › </text>
      <text class="pc-dname">{{currentDishName}}</text>
    </view>
    <view class="pc-text">{{progressText}}</view>
    <view class="pc-stats">
      <view class="pcs success">✅ {{totalSuccess}}</view>
      <view class="pcs skip">⏭ {{totalSkipped}}</view>
      <view class="pcs fail">❌ {{totalFailed}}</view>
    </view>
    <!-- 暂停/继续/停止按钮 -->
    <view class="ctrl-row" wx:if="{{isRunning}}">
      <button class="btn-ctrl pause"  bindtap="onPause"  wx:if="{{!isPaused}}">⏸ 暂停</button>
      <button class="btn-ctrl resume" bindtap="onResume" wx:if="{{isPaused}}"> ▶ 继续</button>
      <button class="btn-ctrl stop"   bindtap="onStop">⏹ 停止</button>
    </view>
  </view>

  <!-- ====== 操作按钮 ====== -->
  <view class="card">
    <view class="card-title">🚀 操作</view>
    <view class="btn-row">
      <button
        class="btn primary"
        bindtap="onGenerateAll"
        disabled="{{isRunning || isQuerying}}"
        loading="{{isRunning}}"
      >{{isRunning ? '生成中...' : '批量生成全部'}}</button>
      <button
        class="btn secondary"
        bindtap="onRefreshStatus"
        disabled="{{isRunning || isQuerying}}"
        loading="{{isQuerying}}"
      >{{isQuerying ? '查询中...' : '刷新状态'}}</button>
    </view>
    <view class="btn-row">
      <button class="btn outline" bindtap="onInitCuisinesData" disabled="{{isRunning}}">初始化菜系数据</button>
      <button class="btn outline" bindtap="onInitSpecialData"  disabled="{{isRunning}}">初始化特色餐数据</button>
    </view>
  </view>

  <!-- ====== 菜系列表 ====== -->
  <view class="card">
    <view class="card-title">🗂️ 菜系列表（{{cuisineList.length}} 个）</view>
    <view class="cuisine-list">
      <view
        class="citem {{item.status}}"
        wx:for="{{cuisineList}}"
        wx:key="id"
      >
        <!-- 顶行 -->
        <view class="citem-top">
          <view class="citem-left">
            <text class="citem-emoji">{{item.emoji}}</text>
            <view class="citem-info">
              <view class="citem-name-row">
                <text class="citem-name">{{item.name}}</text>
                <view class="cbadge {{item.status}}" wx:if="{{item.status !== 'idle'}}">
                  <text wx:if="{{item.status === 'running'}}">生成中</text>
                  <text wx:elif="{{item.status === 'done'}}">完成</text>
                  <text wx:elif="{{item.status === 'partial'}}">部分完成</text>
                  <text wx:elif="{{item.status === 'pending'}}">队列中</text>
                  <text wx:elif="{{item.status === 'error'}}">失败</text>
                </view>
              </view>
              <view class="ctags">
                <text class="ctag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
              </view>
            </view>
          </view>
          <view class="citem-right">
            <text class="cnt-done">{{item.recipeCount}}</text>
            <text class="cnt-sep">/</text>
            <text class="cnt-total">{{item.dishCount}}</text>
          </view>
        </view>

        <!-- 进度条 -->
        <view class="mini-bar-track">
          <view class="mini-bar-fill" style="width:{{item.recipePercent}}%; background:{{item.color}}"></view>
        </view>

        <!-- 本次统计 -->
        <view class="citem-stats" wx:if="{{item.successCount > 0 || item.skippedCount > 0 || item.failedCount > 0}}">
          <text wx:if="{{item.successCount > 0}}" class="cs success">+{{item.successCount}}</text>
          <text wx:if="{{item.skippedCount > 0}}" class="cs skip">⏭{{item.skippedCount}}</text>
          <text wx:if="{{item.failedCount  > 0}}" class="cs fail">✗{{item.failedCount}}</text>
        </view>

        <!-- 操作按钮 -->
        <view class="citem-btns" wx:if="{{!isRunning}}">
          <button
            class="btn-sm gen"
            data-cuisine-id="{{item.id}}"
            bindtap="onGenerateSingle"
            wx:if="{{item.recipeCount < item.dishCount}}"
          >生成菜谱</button>
          <button
            class="btn-sm regen"
            data-cuisine-id="{{item.id}}"
            bindtap="onRegenerateSingle"
          >重新生成</button>
          <text class="done-tag" wx:if="{{item.recipeCount >= item.dishCount}}">✅ 已完成</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ====== 日志 ====== -->
  <view class="card">
    <view class="card-title log-toggle" bindtap="onToggleLogs">
      <text>📋 操作日志（{{logs.length}}）</text>
      <text class="toggle-icon">{{showLogs ? '▲' : '▼'}}</text>
    </view>
    <view wx:if="{{showLogs}}">
      <button class="btn-sm regen" style="margin-bottom:12rpx" bindtap="onClearLogs">清空</button>
      <view class="log-box">
        <view class="log-item" wx:for="{{logs}}" wx:key="index">{{item}}</view>
        <view class="log-empty" wx:if="{{!logs.length}}">暂无日志</view>
      </view>
    </view>
  </view>

  <view class="footer-tip">⚠️ 管理员工具 · 批量生成耗时较长，可分多次完成</view>

</view>
