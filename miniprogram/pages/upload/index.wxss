.page-container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

/* 通用按钮 */
.btn {
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  text-align: center;
}

/* 主按钮（蓝色） */
.primary {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: #fff;
  border: none;
}

/* 次按钮（灰色） */
.secondary {
  background: #f5f5f5;
  color: #333;
  border: none;
}