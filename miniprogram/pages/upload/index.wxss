/* pages/upload/index.wxss  v5.0.0 */

page { background: #f0f2f5; }

.page { padding: 20rpx 20rpx 80rpx; }

/* ====== 页头 ====== */
.page-header {
  background: linear-gradient(135deg, #1565c0, #0d47a1);
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 20rpx;
  color: #fff;
}
.header-row    { display: flex; align-items: center; gap: 16rpx; }
.header-icon   { font-size: 52rpx; }
.header-title  { font-size: 34rpx; font-weight: bold; }
.header-sub    { font-size: 22rpx; color: rgba(255,255,255,.65); margin-top: 4rpx; }

/* ====== 通用 Card ====== */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
}
.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 20rpx;
}

/* ====== 数据库总览 ====== */
.summary-row { display: flex; justify-content: space-around; margin-bottom: 20rpx; }
.summary-item { display: flex; flex-direction: column; align-items: center; }
.sum-num      { font-size: 52rpx; font-weight: bold; color: #333; }
.sum-num.blue  { color: #1565c0; }
.sum-num.orange{ color: #e65100; }
.sum-num.green { color: #2e7d32; }
.sum-label { font-size: 22rpx; color: #888; margin-top: 2rpx; }

/* ====== 进度条（通用）====== */
.pbar-row  { display: flex; align-items: center; gap: 14rpx; }
.pbar-track {
  flex: 1;
  height: 14rpx;
  background: #e8eaf6;
  border-radius: 7rpx;
  overflow: hidden;
}
.pbar-fill {
  height: 100%;
  background: linear-gradient(90deg, #1565c0, #42a5f5);
  border-radius: 7rpx;
  transition: width .3s;
}
.pbar-fill.running {
  background: linear-gradient(90deg, #e65100, #ffb300);
  animation: pulse 1.4s ease-in-out infinite;
}
.pbar-fill.paused { background: #90a4ae; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.55} }
.pbar-pct { font-size: 24rpx; color: #666; min-width: 76rpx; text-align: right; }

/* ====== 实时进度卡片 ====== */
.progress-card { border-left: 6rpx solid #e65100; }
.progress-card.paused { border-left-color: #90a4ae; }
.pc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14rpx; }
.pc-title  { font-size: 28rpx; font-weight: bold; color: #333; }
.pc-pct    { font-size: 32rpx; font-weight: bold; color: #1565c0; }
.pc-dish   { display: flex; align-items: center; margin: 10rpx 0; }
.pc-cuisine{ font-size: 26rpx; color: #555; }
.pc-arrow  { font-size: 24rpx; color: #bbb; margin: 0 6rpx; }
.pc-dname  { font-size: 26rpx; color: #1565c0; font-weight: 500; }
.pc-text   { font-size: 24rpx; color: #666; margin: 8rpx 0 14rpx; }
.pc-stats  { display: flex; gap: 24rpx; }
.pcs       { font-size: 28rpx; font-weight: bold; }
.pcs.success{ color: #2e7d32; }
.pcs.skip  { color: #1565c0; }
.pcs.fail  { color: #b71c1c; }

/* 控制按钮 */
.ctrl-row  { display: flex; gap: 16rpx; margin-top: 20rpx; }
.btn-ctrl  {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: none;
  text-align: center;
}
.btn-ctrl.pause  { background: #fff3e0; color: #e65100; }
.btn-ctrl.resume { background: #e8f5e9; color: #2e7d32; }
.btn-ctrl.stop   { background: #ffebee; color: #b71c1c; }

/* ====== 操作按钮 ====== */
.btn-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
  text-align: center;
  font-weight: 500;
}
.btn.primary  { background: linear-gradient(135deg,#1565c0,#0d47a1); color:#fff; }
.btn.secondary{ background: #f5f5f5; color: #333; }
.btn.outline  { background: #fff; color: #1565c0; border: 2rpx solid #1565c0; font-size: 26rpx; }
.btn[disabled]{ opacity: .45; }

/* ====== 菜系列表 ====== */
.cuisine-list { display: flex; flex-direction: column; gap: 16rpx; }
.citem {
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  padding: 18rpx;
  transition: border-color .2s, background .2s;
}
.citem.running { border-color: #e65100; background: #fff8f0; }
.citem.done    { border-color: #a5d6a7; background: #f1f8e9; }
.citem.partial { border-color: #ffe082; background: #fffde7; }
.citem.error   { border-color: #ef9a9a; background: #fff5f5; }
.citem.pending { border-color: #b0bec5; }

.citem-top  { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10rpx; }
.citem-left { display: flex; align-items: center; gap: 14rpx; flex: 1; }
.citem-emoji{ font-size: 42rpx; }
.citem-info { flex: 1; }
.citem-name-row { display: flex; align-items: center; gap: 10rpx; margin-bottom: 6rpx; }
.citem-name { font-size: 28rpx; font-weight: bold; color: #222; }

.cbadge { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 20rpx; color: #fff; }
.cbadge.running { background: #e65100; }
.cbadge.done    { background: #2e7d32; }
.cbadge.partial { background: #f9a825; color: #333; }
.cbadge.pending { background: #78909c; }
.cbadge.error   { background: #b71c1c; }

.ctags { display: flex; gap: 8rpx; flex-wrap: wrap; }
.ctag  { font-size: 20rpx; color: #888; background: #f0f0f0; padding: 2rpx 10rpx; border-radius: 10rpx; }

.citem-right  { display: flex; align-items: baseline; }
.cnt-done     { font-size: 36rpx; font-weight: bold; color: #1565c0; }
.cnt-sep      { font-size: 22rpx; color: #bbb; margin: 0 2rpx; }
.cnt-total    { font-size: 22rpx; color: #aaa; }

/* 菜系进度条 */
.mini-bar-track {
  height: 6rpx;
  background: #eee;
  border-radius: 3rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.mini-bar-fill { height: 100%; border-radius: 3rpx; transition: width .4s; }

/* 本次统计 */
.citem-stats { display: flex; gap: 14rpx; margin-bottom: 8rpx; }
.cs           { font-size: 22rpx; font-weight: bold; }
.cs.success   { color: #2e7d32; }
.cs.skip      { color: #1565c0; }
.cs.fail      { color: #b71c1c; }

/* 操作按钮 */
.citem-btns { display: flex; gap: 12rpx; align-items: center; margin-top: 4rpx; }
.btn-sm {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 20rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  border: none;
}
.btn-sm.gen   { background: linear-gradient(135deg,#1565c0,#42a5f5); color: #fff; }
.btn-sm.regen { background: #fff; color: #e65100; border: 2rpx solid #e65100; }
.done-tag     { font-size: 24rpx; color: #2e7d32; font-weight: 500; }

/* ====== 日志 ====== */
.log-toggle   { display: flex; justify-content: space-between; cursor: pointer; }
.toggle-icon  { font-size: 24rpx; color: #888; font-weight: normal; }
.log-box {
  background: #1a1a2e;
  border-radius: 12rpx;
  padding: 16rpx;
  max-height: 480rpx;
  overflow-y: auto;
}
.log-item  { font-size: 22rpx; color: #a0d468; font-family: monospace; line-height: 1.7; word-break: break-all; }
.log-empty { font-size: 24rpx; color: #555; text-align: center; padding: 30rpx; }

/* ====== 页脚 ====== */
.footer-tip { text-align: center; font-size: 22rpx; color: #999; padding: 20rpx; }
