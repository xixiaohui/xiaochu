/* 菜系列表页样式 - cuisine/index.wxss */

page {
  background-color: #F5F5F5;
  padding-bottom: 0;
}

.cuisine-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 120rpx;
}

/* ==================== 搜索栏 ==================== */
.search-bar {
  background: #FF6B35;
  padding: 16rpx 24rpx 20rpx;
}

.search-input-wrap {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  height: 72rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 72rpx;
  line-height: 72rpx;
}

.search-placeholder {
  color: #BBBBBB;
  font-size: 28rpx;
}

.search-clear {
  font-size: 36rpx;
  color: #BBBBBB;
  padding: 0 4rpx;
}

/* ==================== 筛选标签栏 ==================== */
.filter-scroll {
  background: #FFFFFF;
  white-space: nowrap;
}

.filter-tags {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  white-space: nowrap;
}

.filter-tag {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666666;
  background: #F5F5F5;
  border: 2rpx solid #E8E8E8;
  white-space: nowrap;
  flex-shrink: 0;
}

.filter-tag-active {
  background: linear-gradient(135deg, #FF6B35, #FF8C42) !important;
  color: #FFFFFF !important;
  border-color: #FF6B35 !important;
  font-weight: 600;
}

/* ==================== 结果提示 ==================== */
.result-tip {
  padding: 16rpx 28rpx 8rpx;
}

.result-count {
  font-size: 24rpx;
  color: #AAAAAA;
}

/* ==================== 菜系卡片列表 ==================== */
.cuisine-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 12rpx 24rpx;
}

.cuisine-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* 卡片头部：彩色背景 */
.card-header {
  padding: 28rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  position: relative;
  overflow: hidden;
}

.card-header::after {
  content: '';
  position: absolute;
  right: -30rpx;
  bottom: -30rpx;
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.card-emoji-wrap {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.card-emoji {
  font-size: 44rpx;
}

.card-header-info {
  flex: 1;
}

.card-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.card-sub-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.card-dish-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

/* 卡片正文 */
.card-body {
  padding: 24rpx 28rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.card-tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid;
  font-weight: 500;
}

/* 操作按钮组 */
.card-actions {
  display: flex;
  gap: 16rpx;
}

.card-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.card-btn-primary {
  color: #FFFFFF;
}

.card-btn-secondary {
  background: transparent;
  border: 2rpx solid;
}

/* ==================== 空结果 ==================== */
.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 16rpx;
}

.empty-emoji {
  font-size: 80rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  font-weight: 500;
}

.empty-sub {
  font-size: 26rpx;
  color: #AAAAAA;
}
