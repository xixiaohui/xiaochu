<!-- 首页 - 小厨AI v3.0 -->
<!-- 功能：轮播banner + 菜系导航 + 热门食材 + 减脂菜谱 + 孕妇营养餐 + 今日推荐 -->

<view class="home-container">

  <!-- ========== 顶部标题区 ========== -->
  <!-- <view class="home-header">
    <view class="header-left">
      <image class="header-logo" src="/images/icon3.png" mode="aspectFit"></image>
      <view class="header-text">
        <view class="header-title">小厨AI</view>
        <view class="header-sub">v3.0 · 多菜系智能烹饪</view>
      </view>
    </view>
  </view> -->

  <!-- ========== 轮播 Banner ========== -->
  <swiper
    class="banner-swiper"
    autoplay="{{true}}"
    interval="3500"
    circular="{{true}}"
    indicator-dots="{{true}}"
    indicator-color="rgba(255,255,255,0.5)"
    indicator-active-color="#FFFFFF"
    bindchange="onBannerChange"
  >
    <swiper-item
      wx:for="{{bannerList}}"
      wx:key="id"
      bindtap="onBannerTap"
      data-action="{{item.action}}"
    >
      <view class="banner-card" style="background: {{item.bgColor}};">
        <view class="banner-emoji">{{item.emoji}}</view>
        <view class="banner-content">
          <view class="banner-title">{{item.title}}</view>
          <view class="banner-subtitle">{{item.subtitle}}</view>
        </view>
        <view class="banner-arrow">›</view>
      </view>
    </swiper-item>
  </swiper>

  <!-- ========== 核心功能入口 ========== -->
  <view class="func-grid">
    <!-- <view class="func-item func-item-main" bindtap="goToRecipe">
      <view class="func-icon-wrap func-icon-orange">
        <text class="func-icon">✨</text>
      </view>
      <view class="func-info">
        <view class="func-name">AI生成菜谱</view>
        <view class="func-desc">输入食材，一键生成</view>
      </view>
      <view class="func-arrow">›</view>
    </view> -->

    <view class="func-item func-item-sub" bindtap="goToCuisineList">
      <view class="func-icon-wrap func-icon-purple">
        <text class="func-icon">🍜</text>
      </view>
      <view class="func-info">
        <view class="func-name">菜系探索</view>
        <view class="func-desc">八大菜系 · 百味中华</view>
      </view>
      <view class="func-arrow">›</view>
    </view>
  </view>

  <!-- ========== 今天吃什么 - 每日推荐 ========== -->
  <view class="section-block daily-section" wx:if="{{dailyRecommendation}}">
    <view class="section-title-row">
      <text class="section-title">🌟 今天吃什么</text>
      <text class="section-more" bindtap="refreshDailyRecommendation">换一道</text>
    </view>
    <!-- cuisine 类型：点击跳菜系详情；其余类型：点击跳 AI 生成 -->
    <view
      class="daily-card"
      bindtap="onDailyRecommendationTap"
      data-source-type="{{dailyRecommendation.sourceType}}"
      data-cuisine-id="{{dailyRecommendation.cuisineId}}"
    >
      <view class="daily-left" style="background: {{dailyRecommendation.color}};">
        <text class="daily-emoji">{{dailyRecommendation.emoji}}</text>
      </view>
      <view class="daily-content">
        <view class="daily-header-row">
          <text class="daily-name">{{dailyRecommendation.name}}</text>
          <view class="daily-badge" style="background: {{dailyRecommendation.color}}20; color: {{dailyRecommendation.color}};">
            {{dailyRecommendation.sourceName}}
          </view>
        </view>
        <text class="daily-desc">{{dailyRecommendation.desc}}</text>
        <view class="daily-meta">
          <text class="daily-meta-item">⏱ {{dailyRecommendation.cookTime}}分钟</text>
          <text class="daily-meta-sep">·</text>
          <text class="daily-meta-item">{{dailyRecommendation.difficulty === 'easy' ? '简单' : dailyRecommendation.difficulty === 'medium' ? '中等' : '困难'}}</text>
          <text class="daily-meta-sep" wx:if="{{dailyRecommendation.calories}}">·</text>
          <text class="daily-meta-item" wx:if="{{dailyRecommendation.calories}}">🔥 {{dailyRecommendation.calories}}卡</text>
        </view>
        <view class="daily-tags">
          <text
            class="daily-tag"
            wx:for="{{dailyRecommendation.tags}}"
            wx:for-item="tag"
            wx:key="index"
          >{{tag}}</text>
        </view>
        <!-- 跳转提示 -->
        <view class="daily-hint">
          {{dailyRecommendation.sourceType === 'cuisine' ? '👉 点击查看菜系详情' : '👉 点击 AI 生成菜谱'}}
        </view>
      </view>
      <view class="daily-arrow-btn" style="background: {{dailyRecommendation.color}};">›</view>
    </view>
  </view>

  <!-- ========== 热门食材快速入口 ========== -->
  <!-- <view class="section-block">
    <view class="section-title-row">
      <text class="section-title">🔥 热门食材直达</text>
      <text class="section-more" bindtap="goToRecipe">自定义 ›</text>
    </view>
    <view class="hot-ingredients-grid">
      <view
        class="hot-ing-item"
        wx:for="{{hotIngredients}}"
        wx:key="name"
        bindtap="onHotIngredientTap"
        data-ingredients="{{item.ingredients}}"
      >
        <text class="hot-ing-emoji">{{item.emoji}}</text>
        <text class="hot-ing-name">{{item.name}}</text>
      </view>
    </view>
  </view> -->

  <!-- ========== 减脂菜谱板块 ========== -->
  <view class="section-block">
    <view class="section-title-row">
      <text class="section-title">🥗 减脂菜谱</text>
      <text class="section-more" bindtap="goToCuisineList">更多 ›</text>
    </view>
    <!-- 竖向列表，内容显示完全 -->
    <view class="meal-list">
      <view
        class="meal-row fat-loss-row"
        wx:for="{{fatLossMeals}}"
        wx:key="id"
        bindtap="onFatLossMealTap"
        data-name="{{item.name}}"
        data-ingredients="{{item.ingredients}}"
        data-cuisineid="{{item.cuisineId}}"
      >
        <!-- 左侧色块 -->
        <view class="meal-row-left fat-loss-left">
          <text class="meal-row-emoji">🥗</text>
          <text class="meal-row-cal">{{item.calories}}卡</text>
        </view>
        <!-- 右侧内容 -->
        <view class="meal-row-body">
          <view class="meal-row-name-line">
            <text class="meal-row-name">{{item.name}}</text>
            <view class="meal-row-diff diff-{{item.difficulty}}">
              {{item.difficulty === 'easy' ? '简单' : item.difficulty === 'medium' ? '中等' : '困难'}}
            </view>
          </view>
          <text class="meal-row-desc">{{item.desc}}</text>
          <view class="meal-row-meta">
            <text class="meal-meta-item">⏱ {{item.cookTime}}分钟</text>
            <text class="meal-meta-sep">·</text>
            <text class="meal-meta-item">蛋白 {{item.protein}}g</text>
            <text class="meal-meta-sep">·</text>
            <text class="meal-meta-item">碳水 {{item.carbs}}g</text>
          </view>
          <view class="meal-row-tags">
            <text
              class="meal-tag fat-loss-tag"
              wx:for="{{item.tags}}"
              wx:for-item="tag"
              wx:key="index"
            >{{tag}}</text>
          </view>
        </view>
        <view class="meal-row-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- ========== 孕妇营养餐板块 ========== -->
  <view class="section-block">
    <view class="section-title-row">
      <text class="section-title">🤰 孕妇营养餐</text>
      <text class="section-more" bindtap="goToCuisineList">更多 ›</text>
    </view>
    <!-- 竖向列表，内容显示完全 -->
    <view class="meal-list">
      <view
        class="meal-row pregnancy-row"
        wx:for="{{pregnancyMeals}}"
        wx:key="id"
        bindtap="onPregnancyMealTap"
        data-name="{{item.name}}"
        data-ingredients="{{item.ingredients}}"
        data-cuisineid="{{item.cuisineId}}"
      >
        <!-- 左侧色块 -->
        <view class="meal-row-left pregnancy-left">
          <text class="meal-row-emoji">🤰</text>
          <text class="meal-row-cal">{{item.calories}}卡</text>
        </view>
        <!-- 右侧内容 -->
        <view class="meal-row-body">
          <view class="meal-row-name-line">
            <text class="meal-row-name">{{item.name}}</text>
            <view class="meal-row-diff diff-{{item.difficulty}}">
              {{item.difficulty === 'easy' ? '简单' : item.difficulty === 'medium' ? '中等' : '困难'}}
            </view>
          </view>
          <text class="meal-row-desc">{{item.desc}}</text>
          <view class="meal-row-meta">
            <text class="meal-meta-item">⏱ {{item.cookTime}}分钟</text>
            <text class="meal-meta-sep">·</text>
            <text class="meal-meta-item">{{item.nutrients[0]}}</text>
            <text class="meal-meta-sep" wx:if="{{item.nutrients[1]}}">·</text>
            <text class="meal-meta-item" wx:if="{{item.nutrients[1]}}">{{item.nutrients[1]}}</text>
          </view>
          <view class="meal-row-tags">
            <text
              class="meal-tag pregnancy-tag"
              wx:for="{{item.tags}}"
              wx:for-item="tag"
              wx:key="index"
            >{{tag}}</text>
          </view>
        </view>
        <view class="meal-row-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- ========== 菜系导航宫格 ========== -->
  <view class="section-block">
    <view class="section-title-row">
      <text class="section-title">🗺️ 菜系导航</text>
      <text class="section-more" bindtap="goToCuisineList">全部 ›</text>
    </view>
    <view class="cuisine-grid">
      <view
        class="cuisine-grid-item"
        wx:for="{{cuisineList}}"
        wx:key="id"
        bindtap="goToCuisineDetail"
        data-id="{{item.id}}"
        style="background: {{item.lightColor}}; border-color: {{item.color}}20;"
      >
        <text class="cuisine-grid-emoji">{{item.emoji}}</text>
        <text class="cuisine-grid-name" style="color: {{item.color}};">{{item.name}}</text>
        <text class="cuisine-grid-desc">{{item.description}}</text>
        <view class="cuisine-grid-tags">
          <text
            class="cuisine-grid-tag"
            wx:for="{{item.tags}}"
            wx:for-item="tag"
            wx:key="index"
            style="color: {{item.color}}; border-color: {{item.color}}40; background: {{item.color}}15;"
          >{{tag}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 今日精选推荐 ========== -->
  <view class="section-block">
    <view class="section-title-row">
      <text class="section-title">⭐ 今日精选菜系</text>
      <text class="section-more" bindtap="refreshFeaturedCuisines">换一换</text>
    </view>
    <view class="featured-list">
      <view
        class="featured-item"
        wx:for="{{featuredCuisines}}"
        wx:key="id"
        bindtap="goToCuisineDetail"
        data-id="{{item.id}}"
      >
        <view class="featured-left" style="background: {{item.color}};">
          <text class="featured-emoji">{{item.emoji}}</text>
        </view>
        <view class="featured-info">
          <view class="featured-name">{{item.name}}</view>
          <view class="featured-desc">{{item.description}}</view>
          <view class="featured-tags">
            <text
              class="featured-tag"
              wx:for="{{item.tags}}"
              wx:for-item="tag"
              wx:key="index"
            >{{tag}}</text>
          </view>
        </view>
        <view class="featured-count">{{item.dishCount}}道菜 ›</view>
      </view>
    </view>
  </view>

  <!-- 底部版本信息 -->
  <view class="home-footer">
    <text class="footer-text">小厨AI {{version}} · 由腾讯混元大模型驱动</text>
  </view>

</view>
