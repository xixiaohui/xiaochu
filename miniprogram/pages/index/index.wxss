/* 首页样式 - index.wxss v3.0 */
/* 设计：暖橙主色、卡片式布局、清爽现代风格 */

page {
  background-color: #F5F5F5;
  padding-bottom: 0;
}

/* ==================== 主容器 ==================== */
.home-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

/* ==================== 顶部标题栏 ==================== */
.home-header {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  padding: 80rpx 32rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.header-logo {
  width: 72rpx;
  height: 72rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.header-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* ==================== 轮播 Banner ==================== */
.banner-swiper {
  height: 350rpx;
  margin: 0;
}

.banner-card {
  height: 350rpx;
  display: flex;
  align-items: center;
  padding: 0 36rpx;
  position: relative;
  overflow: hidden;
}

.banner-card::before {
  content: '';
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.banner-emoji {
  font-size: 72rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.banner-content {
  flex: 1;
}

.banner-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.banner-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
}

/* ==================== 功能入口宫格 ==================== */
.func-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 20rpx 24rpx 0;
}

.func-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.func-item-main {
  border-left: 6rpx solid #FF6B35;
}

.func-item-sub {
  border-left: 6rpx solid #9C27B0;
}

.func-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.func-icon-orange {
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
}

.func-icon-purple {
  background: linear-gradient(135deg, #9C27B0, #CE93D8);
}

.func-icon {
  font-size: 44rpx;
}

.func-info {
  flex: 1;
}

.func-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 6rpx;
}

.func-desc {
  font-size: 24rpx;
  color: #999999;
}

.func-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  font-weight: 300;
}

/* ==================== 通用区块 ==================== */
.section-block {
  margin: 24rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
}

.section-more {
  font-size: 26rpx;
  color: #FF6B35;
}

/* ==================== 今天吃什么 - 每日推荐 ==================== */
.daily-section {
  border-left: 6rpx solid #FF6B35;
}

.daily-card {
  display: flex;
  align-items: stretch;
  background: linear-gradient(135deg, #FFFBF8 0%, #FFF5EE 100%);
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #FFE4D6;
  gap: 0;
}

.daily-left {
  width: 100rpx;
  min-height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 14rpx 0 0 14rpx;
}

.daily-emoji {
  font-size: 48rpx;
}

.daily-content {
  flex: 1;
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.daily-header-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.daily-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2D2D;
}

.daily-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.daily-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.4;
}

.daily-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.daily-meta-item {
  font-size: 22rpx;
  color: #888888;
}

.daily-meta-sep {
  font-size: 22rpx;
  color: #CCCCCC;
}

.daily-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.daily-tag {
  font-size: 20rpx;
  color: #FF6B35;
  background: #FFF0E8;
  border-radius: 12rpx;
  padding: 4rpx 12rpx;
}

.daily-arrow-btn {
  width: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 32rpx;
  color: #FFFFFF;
  border-radius: 0 14rpx 14rpx 0;
}

/* ==================== 热门食材 ==================== */
.hot-ingredients-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.hot-ing-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 12rpx;
  background: #FFF8F5;
  border-radius: 16rpx;
  border: 2rpx solid #FFE4D6;
}

.hot-ing-emoji {
  font-size: 40rpx;
}

.hot-ing-name {
  font-size: 24rpx;
  color: #555555;
  font-weight: 500;
}

/* ==================== 减脂餐 & 孕妇餐 卡片 ==================== */
.special-meal-scroll {
  margin: 0 -28rpx;
  padding: 0 28rpx;
}

.meal-scroll-view {
  display: flex;
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.meal-card {
  display: inline-flex;
  flex-direction: column;
  width: 240rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
  vertical-align: top;
  white-space: normal;
}

.meal-card-top {
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.fat-loss-top {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
}

.pregnancy-top {
  background: linear-gradient(135deg, #E91E63 0%, #F48FB1 100%);
}

.meal-card-emoji {
  font-size: 40rpx;
}

.meal-card-calories {
  font-size: 22rpx;
  font-weight: 700;
  color: #FFFFFF;
  background: rgba(255,255,255,0.25);
  padding: 4rpx 10rpx;
  border-radius: 20rpx;
}

.pregnancy-calories {
  background: rgba(255,255,255,0.25);
}

.meal-card-body {
  flex: 1;
  padding: 16rpx 16rpx 18rpx;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.meal-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2D2D;
  white-space: normal;
  line-height: 1.3;
}

.meal-card-desc {
  font-size: 22rpx;
  color: #888888;
  line-height: 1.4;
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.meal-card-meta {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meal-meta-item {
  font-size: 20rpx;
  color: #AAAAAA;
}

.meal-meta-sep {
  font-size: 20rpx;
  color: #CCCCCC;
}

.meal-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.meal-tag {
  font-size: 18rpx;
  padding: 3rpx 10rpx;
  border-radius: 12rpx;
}

.fat-loss-tag {
  color: #4CAF50;
  background: #E8F5E9;
}

.pregnancy-tag {
  color: #E91E63;
  background: #FCE4EC;
}

/* ==================== 菜系宫格 ==================== */
.cuisine-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.cuisine-grid-item {
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  border: 2rpx solid #F0F0F0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.cuisine-grid-emoji {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

.cuisine-grid-name {
  font-size: 28rpx;
  font-weight: 600;
}

.cuisine-grid-desc {
  font-size: 20rpx;
  color: #888888;
  text-align: center;
  line-height: 1.4;
}

.cuisine-grid-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  justify-content: center;
  margin-top: 4rpx;
}

.cuisine-grid-tag {
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 16rpx;
  border: 1rpx solid;
}

/* ==================== 今日精选 ==================== */
.featured-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.featured-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 20rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
}

.featured-left {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.featured-emoji {
  font-size: 44rpx;
}

.featured-info {
  flex: 1;
}

.featured-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 6rpx;
}

.featured-desc {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 8rpx;
}

.featured-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.featured-tag {
  font-size: 20rpx;
  color: #FF6B35;
  background: #FFF0E8;
  border-radius: 12rpx;
  padding: 4rpx 12rpx;
}

.featured-count {
  font-size: 24rpx;
  color: #FF6B35;
  flex-shrink: 0;
}

/* ==================== 底部 ==================== */
.home-footer {
  text-align: center;
  padding: 32rpx 0 20rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #CCCCCC;
}
