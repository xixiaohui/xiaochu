{
  "name": "xiaochu-ai",
  "version": "1.0.0",
  "description": "小厨AI - 智能食谱生成小程序",
  "scripts": {
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ],
    "moduleNameMapper": {
      "^wx-server-sdk$": "<rootDir>/tests/__mocks__/wx-server-sdk.js"
    },
    "collectCoverageFrom": [
      "cloudfunctions/**/*.js",
      "miniprogram/utils/**/*.js",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "axios": "^1.6.0"
  }
}
